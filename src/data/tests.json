    "scenarios": [
      {
        "id": "REC-01",
        "title": "Parcours locataire — première location",
        "persona": "Thomas Leroy",
        "steps": [
          "Créer un compte avec email valide",
          "Compléter le profil et le KYC (CNI + selfie)",
          "Rechercher un VSP à moins de 1 km",
          "Consulter la fiche annonce (photos, prix, avis)",
          "Sélectionner un créneau demi-journée demain",
          "Payer par carte (Stripe test 4242...)",
          "Recevoir la confirmation par email et push",
          "Consulter les coordonnées propriétaire J-1"
        ],
        "expectedResult": "Réservation confirmée, dépôt retenu, statut booking = confirmed",
        "status": "passed"
      },
      {
        "id": "REC-02",
        "title": "Parcours propriétaire — publication annonce",
        "persona": "Marie Dupont",
        "steps": [
          "Se connecter avec compte vérifié KYC approved",
          "Ajouter un véhicule (VIN, immatriculation, photos)",
          "Vérifier contrat assurance covers_rental = true",
          "Créer une annonce avec tarifs horaire/journalier",
          "Définir disponibilités sur 2 semaines",
          "Publier et vérifier apparition en recherche"
        ],
        "expectedResult": "Annonce active visible sur la carte, calendrier synchronisé",
        "status": "passed"
      },
      {
        "id": "REC-03",
        "title": "État des lieux et retour véhicule",
        "persona": "Thomas Leroy",
        "steps": [
          "Au départ : prendre 4 photos obligatoires (4 angles)",
          "Confirmer prise en charge — statut booking = active",
          "Au retour : reprendre 4 photos",
          "Signaler une micro-rayure (incident type damage)",
          "Terminer la location — statut booking = completed"
        ],
        "expectedResult": "Incident créé, dépôt partiellement retenu si franchise applicable",
        "status": "in_progress"
      },
      {
        "id": "REC-04",
        "title": "Annulation locataire < 48h",
        "persona": "Henri Moreau",
        "steps": [
          "Réserver un créneau J+1",
          "Annuler 24h avant le début",
          "Vérifier email confirmation annulation",
          "Contrôler remboursement 50% sur compte bancaire"
        ],
        "expectedResult": "Booking cancelled, remboursement partiel sous 5 jours ouvrés",
        "status": "pending"
      },
      {
        "id": "REC-05",
        "title": "Multi-véhicules — dashboard propriétaire pro",
        "persona": "Camille Rousseau",
        "steps": [
          "Se connecter avec compte 3 véhicules",
          "Consulter le dashboard revenus consolidés",
          "Modifier tarif dynamique sur une annonce",
