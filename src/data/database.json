  "sqlSchema": "-- Dryvea Database Schema\n-- MySQL 8+ / MariaDB\n-- Location P2P de v\u00e9hicules\n\nCREATE TABLE utilisateur (\n    id VARCHAR(36) NOT NULL,\n    nom VARCHAR(80) NOT NULL,\n    prenom VARCHAR(80) NOT NULL,\n    email VARCHAR(150) NOT NULL UNIQUE,\n    mot_de_passe VARCHAR(255) NOT NULL,\n    telephone VARCHAR(20),\n    date_naissance DATE,\n    adresse TEXT,\n    ville VARCHAR(100),\n    num_permis VARCHAR(50),\n    permis_verifie TINYINT(1) DEFAULT 0,\n    est_proprietaire TINYINT(1) DEFAULT 0,\n    photo_profil VARCHAR(255),\n    note_moyenne DECIMAL(3,2) DEFAULT 0.00,\n    actif TINYINT(1) DEFAULT 1,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (id),\n    UNIQUE KEY email (email)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE type_voiture (\n    id INT UNSIGNED AUTO_INCREMENT,\n    libelle VARCHAR(60) NOT NULL UNIQUE,\n    PRIMARY KEY (id)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE voiture (\n    id VARCHAR(36) NOT NULL,\n    id_proprietaire VARCHAR(36) NOT NULL,\n    id_type INT UNSIGNED NOT NULL,\n    marque VARCHAR(60) NOT NULL,\n    modele VARCHAR(80) NOT NULL,\n    annee YEAR NOT NULL,\n    couleur VARCHAR(40),\n    immatriculation VARCHAR(20) NOT NULL UNIQUE,\n    kilometrage INT UNSIGNED DEFAULT 0,\n    carburant ENUM('essence','diesel','electrique','hybride','gpl') NOT NULL,\n    boite_vitesse ENUM('manuelle','automatique') NOT NULL,\n    nb_places TINYINT UNSIGNED DEFAULT 5,\n    prix_par_jour DECIMAL(8,2) NOT NULL,\n    caution DECIMAL(8,2) DEFAULT 0.00,\n    ville VARCHAR(100) NOT NULL,\n    adresse TEXT,\n    latitude DECIMAL(10,7),\n    longitude DECIMAL(10,7),\n    disponible TINYINT(1) DEFAULT 1,\n    verifie TINYINT(1) DEFAULT 0,\n    note_moyenne DECIMAL(3,2) DEFAULT 0.00,\n    description TEXT,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (id),\n    UNIQUE KEY immatriculation (immatriculation),\n    KEY id_proprietaire (id_proprietaire),\n    KEY id_type (id_type),\n    FOREIGN KEY (id_proprietaire) REFERENCES utilisateur(id) ON DELETE CASCADE,\n    FOREIGN KEY (id_type) REFERENCES type_voiture(id) ON DELETE RESTRICT\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE photo_voiture (\n    id VARCHAR(36) NOT NULL,\n    id_voiture VARCHAR(36) NOT NULL,\n    chemin VARCHAR(255) NOT NULL,\n    est_principale TINYINT(1) DEFAULT 0,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (id),\n    KEY id_voiture (id_voiture),\n    FOREIGN KEY (id_voiture) REFERENCES voiture(id) ON DELETE CASCADE\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE equipement (\n    id INT UNSIGNED AUTO_INCREMENT,\n    nom VARCHAR(100) NOT NULL UNIQUE,\n    categorie ENUM('confort','securite','multimedia','enfant','pratique') NOT NULL,\n    PRIMARY KEY (id)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE voiture_equipement (\n    id_voiture VARCHAR(36) NOT NULL,\n    id_equipement INT UNSIGNED NOT NULL,\n    PRIMARY KEY (id_voiture, id_equipement),\n    FOREIGN KEY (id_voiture) REFERENCES voiture(id) ON DELETE CASCADE,\n    FOREIGN KEY (id_equipement) REFERENCES equipement(id) ON DELETE CASCADE\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE reservation (\n    id VARCHAR(36) NOT NULL,\n    id_voiture VARCHAR(36) NOT NULL,\n    id_locataire VARCHAR(36) NOT NULL,\n    date_debut DATE NOT NULL,\n    date_fin DATE NOT NULL,\n    nb_jours SMALLINT UNSIGNED NOT NULL,\n    prix_total DECIMAL(10,2) NOT NULL,\n    caution_payee DECIMAL(8,2) DEFAULT 0.00,\n    statut ENUM('en_attente','confirmee','en_cours','terminee','annulee','refusee') DEFAULT 'en_attente',\n    message TEXT,\n    motif_annulation TEXT,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (id),\n    KEY id_voiture (id_voiture),\n    KEY id_locataire (id_locataire),\n    FOREIGN KEY (id_voiture) REFERENCES voiture(id) ON DELETE RESTRICT,\n    FOREIGN KEY (id_locataire) REFERENCES utilisateur(id) ON DELETE RESTRICT\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE avis (\n    id VARCHAR(36) NOT NULL,\n    id_reservation VARCHAR(36) NOT NULL,\n    id_auteur VARCHAR(36) NOT NULL,\n    id_cible VARCHAR(36) NOT NULL,\n    type_cible ENUM('voiture','locataire','proprietaire') NOT NULL,\n    note TINYINT UNSIGNED NOT NULL,\n    commentaire TEXT,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (id),\n    KEY id_reservation (id_reservation),\n    KEY id_auteur (id_auteur),\n    FOREIGN KEY (id_reservation) REFERENCES reservation(id) ON DELETE CASCADE,\n    FOREIGN KEY (id_auteur) REFERENCES utilisateur(id) ON DELETE CASCADE\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE paiement (\n    id VARCHAR(36) NOT NULL,\n    id_reservation VARCHAR(36) NOT NULL,\n    montant DECIMAL(10,2) NOT NULL,\n    methode ENUM('carte','virement','paypal') NOT NULL,\n    statut ENUM('en_attente','valide','refuse','rembourse') DEFAULT 'en_attente',\n    id_transaction VARCHAR(100),\n    date_paiement TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (id),\n    KEY id_reservation (id_reservation),\n    FOREIGN KEY (id_reservation) REFERENCES reservation(id) ON DELETE RESTRICT\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE message (\n    id VARCHAR(36) NOT NULL,\n    id_expediteur VARCHAR(36) NOT NULL,\n    id_reservation VARCHAR(36),\n    contenu TEXT NOT NULL,\n    lu TINYINT(1) DEFAULT 0,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (id),\n    KEY id_expediteur (id_expediteur),\n    KEY id_reservation (id_reservation),\n    FOREIGN KEY (id_expediteur) REFERENCES utilisateur(id) ON DELETE CASCADE,\n    FOREIGN KEY (id_reservation) REFERENCES reservation(id) ON DELETE SET NULL\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE dm (\n    id VARCHAR(36) NOT NULL,\n    id_personne_1 VARCHAR(36) NOT NULL,\n    id_personne_2 VARCHAR(36) NOT NULL,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (id),\n    UNIQUE KEY paire_unique (id_personne_1, id_personne_2),\n    CONSTRAINT dm_chk_ordre CHECK (id_personne_1 < id_personne_2),\n    FOREIGN KEY (id_personne_1) REFERENCES utilisateur(id) ON DELETE CASCADE,\n    FOREIGN KEY (id_personne_2) REFERENCES utilisateur(id) ON DELETE CASCADE\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE dm_message (\n    id_dm VARCHAR(36) NOT NULL,\n    id_message VARCHAR(36) NOT NULL,\n    PRIMARY KEY (id_dm, id_message),\n    UNIQUE KEY id_message (id_message),\n    FOREIGN KEY (id_dm) REFERENCES dm(id) ON DELETE CASCADE,\n    FOREIGN KEY (id_message) REFERENCES message(id) ON DELETE CASCADE\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;\n\nCREATE TABLE admin (\n    id VARCHAR(36) NOT NULL,\n    nom VARCHAR(80) NOT NULL,\n    email VARCHAR(150) NOT NULL UNIQUE,\n    mot_de_passe VARCHAR(255) NOT NULL,\n    role ENUM('super_admin','moderateur','support') DEFAULT 'moderateur',\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,\n    PRIMARY KEY (id),\n    UNIQUE KEY email (email)\n) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;"
}
