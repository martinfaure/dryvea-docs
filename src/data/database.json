    { "table": "insurance", "field": "vehicle_id", "type": "UUID", "nullable": false, "description": "Référence vers le véhicule assuré", "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901" },
    { "table": "insurance", "field": "company_name", "type": "VARCHAR(200)", "nullable": false, "description": "Nom de la compagnie d'assurance", "example": "MAIF" },
    { "table": "insurance", "field": "contract_number", "type": "VARCHAR(100)", "nullable": false, "description": "Numéro de police d'assurance", "example": "MAIF-VSP-2026-001234" },
