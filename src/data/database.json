  "sqlSchema": "-- Dryvea Database Schema\n-- PostgreSQL 16+\n-- P2P Electric VSP Rental Platform\n\nCREATE EXTENSION IF NOT EXISTS \"pgcrypto\";\n\n-- Enums\nCREATE TYPE kyc_status_enum AS ENUM ('pending', 'approved', 'rejected');\nCREATE TYPE vehicle_status_enum AS ENUM ('available', 'rented', 'maintenance', 'inactive');\nCREATE TYPE booking_status_enum AS ENUM ('pending', 'confirmed', 'active', 'completed', 'cancelled');\nCREATE TYPE payment_status_enum AS ENUM ('pending', 'succeeded', 'failed', 'refunded');\nCREATE TYPE incident_status_enum AS ENUM ('open', 'investigating', 'resolved', 'closed');\n\n-- Users\nCREATE TABLE users (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    email VARCHAR(255) NOT NULL UNIQUE,\n    password_hash VARCHAR(255) NOT NULL,\n    first_name VARCHAR(100) NOT NULL,\n    last_name VARCHAR(100) NOT NULL,\n    birth_date DATE NOT NULL,\n    phone VARCHAR(20),\n    avatar_url TEXT,\n    is_verified BOOLEAN NOT NULL DEFAULT FALSE,\n    kyc_status kyc_status_enum NOT NULL DEFAULT 'pending',\n    created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),\n    updated_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),\n    CONSTRAINT chk_users_birth_date CHECK (birth_date <= CURRENT_DATE - INTERVAL '18 years')\n);\n\nCREATE INDEX idx_users_email ON users(email);\nCREATE INDEX idx_users_kyc_status ON users(kyc_status);\n\n-- Vehicles\nCREATE TABLE vehicles (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    owner_id UUID NOT NULL REFERENCES users(id) ON DELETE RESTRICT,\n    brand VARCHAR(100) NOT NULL,\n    model VARCHAR(100) NOT NULL,\n    year INTEGER NOT NULL,\n    vin VARCHAR(17) NOT NULL UNIQUE,\n    license_plate VARCHAR(20) NOT NULL UNIQUE,\n    category VARCHAR(10) NOT NULL DEFAULT 'L6e',\n    max_speed INTEGER NOT NULL DEFAULT 45,\n    battery_capacity DECIMAL(5, 2) NOT NULL,\n    autonomy_km INTEGER NOT NULL,\n    photos_urls JSONB DEFAULT '[]'::jsonb,\n    status vehicle_status_enum NOT NULL DEFAULT 'available',\n    created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),\n    CONSTRAINT chk_vehicles_year CHECK (year >= 2000 AND year <= EXTRACT(YEAR FROM CURRENT_DATE) + 1),\n    CONSTRAINT chk_vehicles_max_speed CHECK (max_speed > 0 AND max_speed <= 45),\n    CONSTRAINT chk_vehicles_battery CHECK (battery_capacity > 0),\n    CONSTRAINT chk_vehicles_autonomy CHECK (autonomy_km > 0)\n);\n\nCREATE INDEX idx_vehicles_owner_id ON vehicles(owner_id);\nCREATE INDEX idx_vehicles_status ON vehicles(status);\nCREATE INDEX idx_vehicles_vin ON vehicles(vin);\n\n-- Listings\nCREATE TABLE listings (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    vehicle_id UUID NOT NULL REFERENCES vehicles(id) ON DELETE CASCADE,\n    title VARCHAR(200) NOT NULL,\n    description TEXT,\n    price_per_hour DECIMAL(8, 2) NOT NULL,\n    price_per_day DECIMAL(8, 2) NOT NULL,\n    deposit_amount DECIMAL(8, 2) NOT NULL DEFAULT 300.00,\n    location_lat DECIMAL(10, 7) NOT NULL,\n    location_lng DECIMAL(10, 7) NOT NULL,\n    location_address VARCHAR(500) NOT NULL,\n    availability_start TIMESTAMP WITH TIME ZONE,\n    availability_end TIMESTAMP WITH TIME ZONE,\n    is_active BOOLEAN NOT NULL DEFAULT TRUE,\n    created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),\n    CONSTRAINT chk_listings_prices CHECK (price_per_hour > 0 AND price_per_day > 0),\n    CONSTRAINT chk_listings_deposit CHECK (deposit_amount >= 0),\n    CONSTRAINT chk_listings_availability CHECK (\n        availability_start IS NULL OR availability_end IS NULL OR availability_start < availability_end\n    )\n);\n\nCREATE INDEX idx_listings_vehicle_id ON listings(vehicle_id);\nCREATE INDEX idx_listings_is_active ON listings(is_active) WHERE is_active = TRUE;\nCREATE INDEX idx_listings_location ON listings(location_lat, location_lng);\n\n-- Bookings\nCREATE TABLE bookings (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    listing_id UUID NOT NULL REFERENCES listings(id) ON DELETE RESTRICT,\n    renter_id UUID NOT NULL REFERENCES users(id) ON DELETE RESTRICT,\n    start_datetime TIMESTAMP WITH TIME ZONE NOT NULL,\n    end_datetime TIMESTAMP WITH TIME ZONE NOT NULL,\n    total_price DECIMAL(10, 2) NOT NULL,\n    service_fee DECIMAL(8, 2) NOT NULL,\n    deposit_held DECIMAL(8, 2) NOT NULL DEFAULT 0,\n    status booking_status_enum NOT NULL DEFAULT 'pending',\n    created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),\n    CONSTRAINT chk_bookings_dates CHECK (start_datetime < end_datetime),\n    CONSTRAINT chk_bookings_total_price CHECK (total_price >= 0),\n    CONSTRAINT chk_bookings_service_fee CHECK (service_fee >= 0)\n);\n\nCREATE INDEX idx_bookings_listing_id ON bookings(listing_id);\nCREATE INDEX idx_bookings_renter_id ON bookings(renter_id);\nCREATE INDEX idx_bookings_status ON bookings(status);\nCREATE INDEX idx_bookings_dates ON bookings(start_datetime, end_datetime);\n\n-- Payments\nCREATE TABLE payments (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    booking_id UUID NOT NULL REFERENCES bookings(id) ON DELETE RESTRICT,\n    amount DECIMAL(10, 2) NOT NULL,\n    currency VARCHAR(3) NOT NULL DEFAULT 'EUR',\n    payment_method VARCHAR(50) NOT NULL,\n    payment_provider VARCHAR(50) NOT NULL DEFAULT 'stripe',\n    provider_ref VARCHAR(255) NOT NULL UNIQUE,\n    status payment_status_enum NOT NULL DEFAULT 'pending',\n    created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),\n    CONSTRAINT chk_payments_amount CHECK (amount > 0),\n    CONSTRAINT chk_payments_currency CHECK (currency = 'EUR')\n);\n\nCREATE INDEX idx_payments_booking_id ON payments(booking_id);\nCREATE INDEX idx_payments_status ON payments(status);\nCREATE INDEX idx_payments_provider_ref ON payments(provider_ref);\n\n-- Reviews\nCREATE TABLE reviews (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    booking_id UUID NOT NULL REFERENCES bookings(id) ON DELETE CASCADE,\n    reviewer_id UUID NOT NULL REFERENCES users(id) ON DELETE RESTRICT,\n    reviewed_id UUID NOT NULL REFERENCES users(id) ON DELETE RESTRICT,\n    rating INTEGER NOT NULL,\n    comment TEXT,\n    created_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),\n    CONSTRAINT chk_reviews_rating CHECK (rating >= 1 AND rating <= 5),\n    CONSTRAINT chk_reviews_not_self CHECK (reviewer_id != reviewed_id),\n    CONSTRAINT uq_reviews_booking_reviewer UNIQUE (booking_id, reviewer_id)\n);\n\nCREATE INDEX idx_reviews_booking_id ON reviews(booking_id);\nCREATE INDEX idx_reviews_reviewed_id ON reviews(reviewed_id);\n\n-- Insurance\nCREATE TABLE insurance (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    vehicle_id UUID NOT NULL REFERENCES vehicles(id) ON DELETE CASCADE,\n    company_name VARCHAR(200) NOT NULL,\n    contract_number VARCHAR(100) NOT NULL UNIQUE,\n    coverage_type VARCHAR(100) NOT NULL,\n    covers_rental BOOLEAN NOT NULL DEFAULT FALSE,\n    expiry_date DATE NOT NULL,\n    CONSTRAINT chk_insurance_expiry CHECK (expiry_date > CURRENT_DATE - INTERVAL '1 year')\n);\n\nCREATE INDEX idx_insurance_vehicle_id ON insurance(vehicle_id);\nCREATE INDEX idx_insurance_expiry_date ON insurance(expiry_date);\n\n-- Incidents\nCREATE TABLE incidents (\n    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n    booking_id UUID NOT NULL REFERENCES bookings(id) ON DELETE RESTRICT,\n    reported_by UUID NOT NULL REFERENCES users(id) ON DELETE RESTRICT,\n    type VARCHAR(50) NOT NULL,\n    description TEXT NOT NULL,\n    photos_urls JSONB DEFAULT '[]'::jsonb,\n    reported_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),\n    status incident_status_enum NOT NULL DEFAULT 'open',\n    CONSTRAINT chk_incidents_type CHECK (type IN ('damage', 'theft', 'breakdown', 'other'))\n);\n\nCREATE INDEX idx_incidents_booking_id ON incidents(booking_id);\nCREATE INDEX idx_incidents_reported_by ON incidents(reported_by);\nCREATE INDEX idx_incidents_status ON incidents(status);\n\n-- Trigger: auto-update updated_at on users\nCREATE OR REPLACE FUNCTION update_updated_at_column()\nRETURNS TRIGGER AS $$\nBEGIN\n    NEW.updated_at = NOW();\n    RETURN NEW;\nEND;\n$$ LANGUAGE plpgsql;\n\nCREATE TRIGGER trg_users_updated_at\n    BEFORE UPDATE ON users\n    FOR EACH ROW\n    EXECUTE FUNCTION update_updated_at_column();"
}
